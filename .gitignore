# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*.kicad_prl
*.sch-bak
*~
_autosave-*
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv
*.pdf


# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.claude
.vscode

# Weekly progress updates for the team — kept local, not pushed
docs/weekly_updates/

# Senior design coursework + reviewer feedback — local-only working copies
# (final design doc, poster source, instructor templates, reviewer notes)
docs/senior_design/

# Firmware build artifacts (CMake + Pico SDK output trees)
# Any directory literally named "build" anywhere in firmware/, plus the
# generated binaries themselves so they don't leak even if someone
# builds in-tree.
firmware/**/build/
*.uf2
*.elf
*.elf.map
*.hex
*.bin
# Keep .a out of git only inside firmware/ to avoid colliding with any
# future hardware footprint libraries elsewhere.
firmware/**/*.a
firmware/**/*.o

# IDE / editor scratch files commonly produced during firmware dev
firmware/**/.vscode/
firmware/**/compile_commands.json
firmware/**/.cache/
